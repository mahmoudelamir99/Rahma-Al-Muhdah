# -----------------------------------------------------------------------------
# Candidate Auth delete (optional — deploy Edge Function first)
# -----------------------------------------------------------------------------
# From repo root: supabase functions deploy delete-candidate-user
# The function requires a valid user session; the admin UI sends Authorization: Bearer (access_token).
# Never put service_role keys in VITE_* vars (exposed to the browser).
# VITE_SUPABASE_DELETE_CANDIDATE_URL="https://YOUR_PROJECT.supabase.co/functions/v1/delete-candidate-user"

# -----------------------------------------------------------------------------
# Realtime (optional)
# -----------------------------------------------------------------------------
# Enable replication for the table in Supabase (Database / Realtime). If subscribe fails, the app still runs;
# a warning is logged to the browser console only.
# VITE_SUPABASE_REALTIME_TABLE="applications"
